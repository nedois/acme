{
  "name": "@nedois/vitest-config",
  "type": "module",
  "version": "0.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./ui": "./dist/configs/ui-config.js",
    "./base": "./dist/configs/base-config.js"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nedois/acme.git",
    "directory": "packages/vitest-config"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . --fix",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "collect-json-reports": "node dist/scripts/collect-json-outputs.js",
    "merge-json-reports": "nyc merge coverage/raw coverage/merged/merged-coverage.json",
    "report": "nyc report -t coverage/merged --report-dir coverage/report --reporter=html --exclude-after-remap false",
    "view-report": "open coverage/report/index.html"
  },
  "dependencies": {
    "vitest": "catalog:"
  },
  "devDependencies": {
    "@nedois/typescript-config": "workspace:*",
    "@nedois/eslint-config": "workspace:*",
    "@vitest/coverage-istanbul": "catalog:",
    "@vitest/ui": "catalog:",
    "glob": "catalog:",
    "jsdom": "catalog:",
    "nyc": "catalog:",
    "typescript": "catalog:"
  }
}